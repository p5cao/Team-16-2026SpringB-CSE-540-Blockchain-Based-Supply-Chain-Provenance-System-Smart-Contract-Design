# copy this to .env and fill in your values
# dont commit .env lol

# --- rpc / contract ---

# regular http rpc, used for the initial backfill when the server starts
RPC_URL=https://sepolia.infura.io/v3/YOUR_INFURA_KEY

# websocket url for live events - grab from infura or alchemy dashboard
# if you leave this blank it just wont subscribe to new events
WS_RPC_URL=wss://sepolia.infura.io/ws/v3/YOUR_INFURA_KEY

# contract address on sepolia - check deployed_addresses.json if you forgot it
CONTRACT_ADDRESS=0xE40395b469F6E5b95E4bE18aC475C2aE40a4EA97

# first block to scan from (set to deployment block so we dont scan all of sepolia)
# you can find the block number in journal.jsonl -> look for receipt.blockNumber near the bottom
START_BLOCK=10758745

# how many blocks to pull per getLogs call - 2000 works fine on free infura
# lower this if you start getting rate limit errors
BLOCK_CHUNK=2000


# --- ipfs ---

# pinata public gateway, swap this out if you use a different provider
IPFS_GATEWAY=https://gateway.pinata.cloud/ipfs


# --- database ---

# where to put the sqlite file, relative to back-end/
DB_PATH=./data/supply_chain.db

# set to true if you want to nuke the db and re-sync everything from START_BLOCK
# useful after contract redeployment, dangerous otherwise
REBUILD_ON_START=false

# ── API Server ────────────────────────────────────────────────────────────────
PORT=3001
