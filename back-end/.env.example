# ── Network & Contract ────────────────────────────────────────────────────────
# Sepolia Infura RPC (HTTP — no WS needed for polling)
RPC_URL=https://sepolia.infura.io/v3/YOUR_INFURA_KEY

# Deployed contract address (from blockchain/ignition/deployments/chain-11155111/deployed_addresses.json)
CONTRACT_ADDRESS=0xE40395b469F6E5b95E4bE18aC475C2aE40a4EA97

# Block number of the contract deployment transaction
# Find it in: blockchain/ignition/deployments/chain-11155111/journal.jsonl (last entry → receipt.blockNumber)
# Setting to 0 scans all Sepolia history — very slow on free RPC tier.
START_BLOCK=10758745

# How many blocks to fetch per query when back-filling (lower = safer on free RPC tier)
BLOCK_CHUNK=2000

# How often (ms) the polling loop checks for new events
POLL_INTERVAL_MS=15000

# ── IPFS ──────────────────────────────────────────────────────────────────────
# Gateway used to fetch stored JSON metadata by CID
IPFS_GATEWAY=https://gateway.pinata.cloud/ipfs

# ── Database ──────────────────────────────────────────────────────────────────
# Path to SQLite file (relative to back-end/ root)
DB_PATH=./data/supply_chain.db

# Set to "true" to wipe all tables and replay all events from START_BLOCK on startup
REBUILD_ON_START=false

# ── API Server ────────────────────────────────────────────────────────────────
PORT=3001
